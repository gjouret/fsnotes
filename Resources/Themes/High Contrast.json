{
    "comment": "FSNotes++ High Contrast theme. Bundled with the app as of Phase 7.4. Accessibility-forward: pure-black chrome on white, maximally-contrasting foregrounds, saturated accent colors, thicker visual dividers. Schema matches default-theme.json exactly.",

    "noteFontName": null,
    "noteFontSize": 14,
    "codeFontName": "Source Code Pro",
    "codeFontSize": 14,

    "editorLineSpacing": 4,
    "lineWidth": 1000,
    "marginSize": 20,

    "lineHeightMultiple": 1.4,
    "italic": "*",
    "bold": "__",

    "headingFontScales": [2.0, 1.7, 1.4, 1.2, 1.1, 1.05],
    "headingSpacingBefore": [1.2, 1.0, 0.9, 0.8, 0.7, 0.6],
    "headingSpacingAfter": [0.67, 0.5, 0.4, 0.35, 0.3, 0.25],

    "paragraphSpacing": 12,

    "codeBlockLineSpacing": 0,
    "codeBlockParagraphSpacing": 16,
    "codeBlockSpacingBefore": 0,

    "listIndentScale": 1.8,
    "listCellScale": 2.0,
    "listBulletSizeScale": 0.7,
    "listNumberDrawScale": 1.0,
    "listCheckboxDrawScale": 1.2,
    "listBulletStrokeInset": 0.5,
    "listBulletStrokeWidth": 1.0,
    "listBlockSpacing": 16,

    "blockquoteBarInitialOffset": 2,
    "blockquoteBarSpacing": 10,
    "blockquoteBarWidth": 4,
    "blockquoteGapAfterBars": 4,
    "blockquoteBlockSpacing": 16,

    "tablePlaceholderWidth": 400,
    "tablePlaceholderHeight": 100,
    "tableBlockSpacing": 16,

    "hrBlockSpacing": 16,

    "htmlBlockLineSpacing": 0,
    "htmlBlockParagraphSpacing": 16,
    "htmlBlockSpacingBefore": 0,

    "highlightColor": {
        "red": 1.0,
        "green": 1.0,
        "blue": 0.0,
        "alpha": 1.0
    },

    "blankLineMinHeight": 0.01,
    "blankLineMaxHeight": 0.01,

    "typography": {
        "bodyFontName": null,
        "bodyFontSize": 14,
        "codeFontName": "Source Code Pro",
        "codeFontSize": 14,
        "kbdFontSizeMultiplier": 0.85,
        "subSuperFontSizeMultiplier": 0.75,
        "inlineCodeSizeMultiplier": 1.0,
        "boldMarker": "**",
        "italicMarker": "*"
    },

    "spacing": {
        "lineHeightMultiple": 1.0,
        "paragraphSpacingMultiplier": 0.85,
        "structuralBlockSpacingMultiplier": 1.1,
        "paragraphSpacing": 12,
        "textContainerInsetHeight": 10,
        "textContainerInsetWidth": 0,
        "lineFragmentPadding": 10
    },

    "colors": {
        "link":                 { "light": "#0000EE", "dark": "#66CCFF" },
        "inlineCodeBackground": { "light": "#000000FF", "dark": "#FFFFFFFF" },
        "highlightBackground":  "#FFFF00FF",
        "blockquoteBar":        "#000000",
        "codeBlockBackground":  { "light": "#F5F5F5", "dark": "#000000" },
        "codeBlockBorder":      "#000000",
        "kbdFill":              "#FFFFFF",
        "kbdStroke":            "#000000",
        "kbdShadow":            "#000000",
        "kbdForeground":        "#000000",
        "hrLine":               "#000000",
        "headingBorder":        "#000000"
    },

    "chrome": {
        "kbdCornerRadius": 3.0,
        "kbdBorderWidth": 2.0,
        "kbdHorizontalPadding": 2.0,
        "kbdVerticalPaddingTop": 1.0,
        "kbdVerticalPaddingBottom": 1.0,
        "inlineCodeCornerRadius": 3.0,
        "inlineCodeBorderWidth": 1.0,
        "inlineCodeHorizontalPadding": 2.0,
        "inlineCodeVerticalPaddingTop": 0.0,
        "inlineCodeVerticalPaddingBottom": 0.0,
        "codeBlockCornerRadius": 3.0,
        "codeBlockHorizontalBleed": 5.0,
        "codeBlockBorderWidth": 2.0,
        "blockquoteBarWidth": 6,
        "blockquoteBarSpacing": 10,
        "blockquoteBarInitialOffset": 2,
        "hrThickness": 6.0,
        "headingBorderThickness": 1.5,
        "headingBorderOffsetBelowText": 1.0,
        "codeBlockEditToggle": {
            "cornerRadius": 3,
            "horizontalPadding": 4,
            "verticalPadding": 2,
            "foreground": { "light": "#000000", "dark": "#FFFFFF" },
            "backgroundHover": "#00000030",
            "backgroundActive": "#00000060"
        },
        "tableHandle": { "light": "#000000FF", "dark": "#FFFFFFFF" },
        "tableResizePreview": { "light": "#0000FFFF", "dark": "#00FFFFFF" },
        "sourceMarker": { "light": "#444444FF", "dark": "#BBBBBBFF" },
        "foldedHeaderIndicatorForeground": { "light": "#FFFFFFFF", "dark": "#000000FF" },
        "foldedHeaderIndicatorBackground": { "light": "#000000FF", "dark": "#FFFFFFFF" },
        "foldedHeaderIndicatorCornerRadius": 2.0,
        "foldedHeaderIndicatorHorizontalPadding": 4.0,
        "foldedHeaderIndicatorVerticalPadding": 1.0,
        "foldedHeaderIndicatorFontSizeMultiplier": 0.6,
        "foldedHeaderIndicatorTrailingGap": 6.0
    }
}
